{
  "version": "0.1.0",
  "name": "anonymous-admin",
  "description": "Anonymous Reporting — admin microapp (triage, resolve, escalate)",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@frontmltd/frontmai-cli": "github:frontmltd/frontmjs-cli",
    "babel-loader": "^10.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "bin": {
    "frontm-build": "./node_modules/@frontmltd/frontmjs/after.js"
  },
  "scripts": {
    "lint": "eslint . --ignore-pattern 'dist/**' --ignore-pattern 'node_modules/**' --max-warnings=100",
    "lint:fix": "eslint . --ignore-pattern 'dist/**' --ignore-pattern 'node_modules/**' --max-warnings=100 --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prebuild": "npm run format:check && npm run lint",
    "build": "webpack --mode=production --node-env=production && npm exec frontm-build",
    "build:dev": "webpack --mode=development && npm exec frontm-build",
    "build:fast": "webpack --mode=production --node-env=production && npm exec frontm-build",
    "build:prod": "npm run lint && npm run format && webpack --mode=production --node-env=production && npm exec frontm-build",
    "deploy": "npm run build && ./node_modules/.bin/frontmai-cli deploy",
    "watch": "webpack --watch"
  },
  "dependencies": {
    "@frontmltd/frontmjs": "github:frontmltd/frontm.js#5.0.b9"
  }
}
